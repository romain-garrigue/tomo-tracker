# Gong — generate at: Gong → Company Settings → API
GONG_ACCESS_KEY=
GONG_ACCESS_KEY_SECRET=
GONG_BASE_URL=https://eu-93246.api.gong.io
GONG_WORKSPACE_ID=6135656620898778750

# Slack — bot token (xoxb-…) with chat:write, invited to every target channel.
# Slack app → OAuth & Permissions → Bot User OAuth Token.
SLACK_BOT_TOKEN=

# Channel IDs (right-click channel → View channel details → ID at the bottom).
# tomo defaults to #tomo-mention-alerts (C0B0CHKC58X) if left blank.
# Leave a channel blank to skip that tracker until its channel exists.
# For a local dry-run, set all of these to your own DM/user ID (e.g. U096JJ1GSAJ).
SLACK_CHANNEL_TOMO=C0B0CHKC58X
SLACK_CHANNEL_MOCHI=
SLACK_CHANNEL_KUMI=
SLACK_CHANNEL_SHIRO_KEN=
SLACK_CHANNEL_PRODUCT_SIGNALS=

# Anthropic — https://console.anthropic.com → API keys
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-7

# State + backfill
STATE_PATH=state/processed_calls.json
BACKFILL_DAYS=7
